# ═══════════════════════════════════════════════════════════════════════════════
# لغة المرجع - Al-Marjaa Language
# ملف Gitignore - إصدار 3.0.0
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Rust - لغة البرمجة
# ─────────────────────────────────────────────────────────────────────────────
/target/
**/target/
*.rs.bk
*.rlib
Cargo.lock  # يتم توليده تلقائياً
**/*.rs.bk

# ─────────────────────────────────────────────────────────────────────────────
# IDE و المحررات
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*
*.iml
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────────────────────
# ملفات البناء
# ─────────────────────────────────────────────────────────────────────────────
*.exe
*.dll
*.so
*.dylib
*.pdb
*.o
*.obj
*.a
*.lib

# ─────────────────────────────────────────────────────────────────────────────
# ملفات مؤقتة
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.cache
*.orig

# ─────────────────────────────────────────────────────────────────────────────
# نماذج AI (ملفات كبيرة)
# ─────────────────────────────────────────────────────────────────────────────
# يتم استثناء ملفات GGUF لأنها كبيرة
# حمل النماذج من HuggingFace
models/*.gguf
models/*.bin
models/*.safetensors

# ─────────────────────────────────────────────────────────────────────────────
# بيئة Python (للتدريب)
# ─────────────────────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.env
.env.local
.env.*.local

# ─────────────────────────────────────────────────────────────────────────────
# مخرجات التصدير
# ─────────────────────────────────────────────────────────────────────────────
/build/
/output/
/dist/
*.app
*.dmg
*.deb
*.rpm

# ─────────────────────────────────────────────────────────────────────────────
# Node.js (للإضافة VS Code)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────
# VS Code Extension
# ─────────────────────────────────────────────────────────────────────────────
editors/vscode/out/
editors/vscode/node_modules/
*.vsix

# ─────────────────────────────────────────────────────────────────────────────
# ملفات التوثيق المُولّدة
# ─────────────────────────────────────────────────────────────────────────────
docs/_build/
docs/.doctrees/

# ─────────────────────────────────────────────────────────────────────────────
# ملفات النسخ الاحتياطي
# ─────────────────────────────────────────────────────────────────────────────
*~
*.backup
*.old
