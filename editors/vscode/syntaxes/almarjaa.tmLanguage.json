{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Al-Marjaa",
  "scopeName": "source.almarjaa",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.almarjaa",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.almarjaa",
          "match": "\\b(廿匕丕|賵廿賱丕|胤丕賱賲丕|賱賰賱|賮賷|丕乇噩毓|兀毓胤賽|鬲兀賰丿)\\b"
        },
        {
          "name": "keyword.declaration.almarjaa",
          "match": "\\b(賲鬲睾賷乇|孬丕亘鬲|丿丕賱丞|賳賵毓|賴賷賰賱|賵丕噩賴丞|賮卅丞|禺丕氐|毓丕賲)\\b"
        },
        {
          "name": "keyword.other.almarjaa",
          "match": "\\b(丕爻鬲賵乇丿|賲賳|賰賭|噩丿賷丿|氐丨賷丨|禺胤兀|賮丕乇睾)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.almarjaa",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.almarjaa",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.almarjaa",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.almarjaa",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.almarjaa",
          "match": "\\b[贍-侃0-9]+(\\.[贍-侃0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.almarjaa",
          "match": "0x[0-9a-fA-F]+"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.almarjaa",
          "match": "(\\+|\\-|\\*|\\/|%)"
        },
        {
          "name": "keyword.operator.comparison.almarjaa",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.almarjaa",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.almarjaa",
          "match": "(=|\\+=|\\-=|\\*=|\\/=)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.almarjaa",
          "match": "\\b(丕胤亘毓|兀丿禺賱|胤賵賱|賳賵毓|鬲丨賵賷賱|賯乇丕亍丞|賰鬲丕亘丞|賮鬲丨|廿睾賱丕賯|賮乇夭|亘丨孬)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.almarjaa",
          "match": "\\b(毓丿丿|賳氐|賲賳胤賯賷|賯丕卅賲丞|賲氐賮賵賮丞|禺乇賷胤丞|Tensor|NeuralNetwork)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.almarjaa",
          "match": "\\b[兀-賷丌-蹞][兀-賷丌-蹞贍-侃0-9_]*\\b"
        }
      ]
    }
  }
}
