{
  "دالة جديدة": {
    "prefix": "دالة",
    "body": [
      "دالة ${1:اسم_الدالة}(${2:المعاملات}) {",
      "\t${3:// الكود هنا}",
      "\tأرجع ${4:النتيجة}",
      "}"
    ],
    "description": "إنشاء دالة جديدة"
  },
  
  "دالة مع نوع": {
    "prefix": "دالةن",
    "body": [
      "دالة ${1:اسم_الدالة}(${2:المعاملات}) -> ${3:النوع} {",
      "\t${4:// الكود هنا}",
      "\tأرجع ${5:النتيجة}",
      "}"
    ],
    "description": "إنشاء دالة مع تحديد نوع الإرجاع"
  },
  
  "متغير جديد": {
    "prefix": "متغير",
    "body": [
      "متغير ${1:الاسم} = ${2:القيمة}"
    ],
    "description": "تعريف متغير جديد"
  },
  
  "ثابت": {
    "prefix": "ثابت",
    "body": [
      "ثابت ${1:الاسم} = ${2:القيمة}"
    ],
    "description": "تعريف ثابت"
  },
  
  "إذا": {
    "prefix": "إذا",
    "body": [
      "إذا ${1:الشرط} {",
      "\t${2:// الكود إذا تحقق الشرط}",
      "} وإلا {",
      "\t${3:// الكود إذا لم يتحقق}",
      "}"
    ],
    "description": "جملة شرطية كاملة"
  },
  
  "إذا فقط": {
    "prefix": "إذا_فقط",
    "body": [
      "إذا ${1:الشرط} {",
      "\t${2:// الكود}",
      "}"
    ],
    "description": "جملة شرطية بدون وإلا"
  },
  
  "بينما": {
    "prefix": "بينما",
    "body": [
      "بينما ${1:الشرط} {",
      "\t${2:// الكود}",
      "}"
    ],
    "description": "حلقة while"
  },
  
  "لكل": {
    "prefix": "لكل",
    "body": [
      "لكل ${1:عنصر} من ${2:المجموعة} {",
      "\t${3:// الكود}",
      "}"
    ],
    "description": "حلقة for each"
  },
  
  "لأجل": {
    "prefix": "لأجل",
    "body": [
      "لأجل متغير ${1:i} = ${2:0}؛ ${1:i} < ${3:النهاية}؛ ${1:i} = ${1:i} + 1 {",
      "\t${4:// الكود}",
      "}"
    ],
    "description": "حلقة for تقليدية"
  },
  
  "اطبع": {
    "prefix": "اطبع",
    "body": [
      "اطبع(\"${1:النص}\")"
    ],
    "description": "طباعة نص"
  },
  
  "اطبع متغير": {
    "prefix": "اطبع_متغير",
    "body": [
      "اطبع(\"${1:الوصف}: \" + ${2:المتغير})"
    ],
    "description": "طباعة متغير مع وصف"
  },
  
  "صف": {
    "prefix": "صف",
    "body": [
      "صف ${1:الاسم} {",
      "\t${2:الحقل1}: ${3:النوع1}",
      "\t${4:الحقل2}: ${5:النوع2}",
      "}"
    ],
    "description": "تعريف struct/صف"
  },
  
  "تعداد": {
    "prefix": "تعداد",
    "body": [
      "تعداد ${1:الاسم} {",
      "\t${2:القيمة1}",
      "\t${3:القيمة2}",
      "}"
    ],
    "description": "تعريف enum/تعداد"
  },
  
  "استيراد": {
    "prefix": "استيراد",
    "body": [
      "استيراد \"${1:الحزمة}\""
    ],
    "description": "استيراد حزمة"
  },
  
  "تصدير": {
    "prefix": "تصدير",
    "body": [
      "تصدير ${1:العنصر}"
    ],
    "description": "تصدير عنصر"
  },
  
  "محاولة": {
    "prefix": "محاولة",
    "body": [
      "محاولة {",
      "\t${1:// الكود الذي قد يفشل}",
      "} التقاط (${2:الخطأ}) {",
      "\t${3:// معالجة الخطأ}",
      "}"
    ],
    "description": "كتلة try/catch"
  },
  
  "فئة": {
    "prefix": "فئة",
    "body": [
      "فئة ${1:الاسم} {",
      "\t${2:// الخصائص}",
      "\t",
      "\tدالة ${3:تهيئة}(${4:المعاملات}) {",
      "\t\t${5:// كود التهيئة}",
      "\t}",
      "\t",
      "\tدالة ${6:طريقة}(${7:المعاملات}) {",
      "\t\t${8:// الكود}",
      "\t}",
      "}"
    ],
    "description": "تعريف فئة/كلاس"
  },
  
  "اختبار": {
    "prefix": "اختبار",
    "body": [
      "اختبار(\"${1:وصف_الاختبار}\", دالة() {",
      "\t${2:// ترتيب}",
      "\tconst نتيجة = ${3:الدالة_المختبرة}()",
      "\t${4:// تحقق}",
      "\tتأكيد(نتيجة == ${5:المتوقع})",
      "})"
    ],
    "description": "إنشاء اختبار"
  },
  
  "تأكيد": {
    "prefix": "تأكيد",
    "body": [
      "تأكيد(${1:الشرط}, \"${2:رسالة_الخطأ}\")"
    ],
    "description": "تأكيد في الاختبار"
  },
  
  "تعليق توثيقي": {
    "prefix": "توثيق",
    "body": [
      "/**",
      " * ${1:الوصف}",
      " * @معامل ${2:الاسم} - ${3:الوصف}",
      " * @إرجاع ${4:الوصف}",
      " */"
    ],
    "description": "تعليق توثيقي"
  },
  
  "دالة سهم": {
    "prefix": "سهم",
    "body": [
      "const ${1:الاسم} = (${2:المعاملات}) => {",
      "\t${3:// الكود}",
      "\tأرجع ${4:النتيجة}",
      "}"
    ],
    "description": "دالة سهمية"
  },
  
  "وعندما": {
    "prefix": "وعندما",
    "body": [
      "وعندما ${1:الشرط} {",
      "\t${2:// الكود}",
      "}"
    ],
    "description": "حالة في switch"
  },
  
  "افتراضي": {
    "prefix": "افتراضي",
    "body": [
      "افتراضي {",
      "\t${1:// الكود}",
      "}"
    ],
    "description": "حالة افتراضية في switch"
  },
  
  "تأخير": {
    "prefix": "تأخير",
    "body": [
      "تأخير(${1:ميلي_ثانية})"
    ],
    "description": "تأخير غير متزامن"
  },
  
  "غير_متزامن": {
    "prefix": "غير_متزامن",
    "body": [
      "غير_متزامن دالة ${1:الاسم}(${2:المعاملات}) {",
      "\t${3:// الكود}",
      "\tأرجع ${4:النتيجة}",
      "}"
    ],
    "description": "دالة غير متزامنة"
  },
  
  "انتظار": {
    "prefix": "انتظار",
    "body": [
      "انتظار ${1:العملية}"
    ],
    "description": "await"
  },
  
  "وعد": {
    "prefix": "وعد",
    "body": [
      "وعد جديد(دالة(حل، رفض) {",
      "\t${1:// الكود}",
      "\tحل(${2:النتيجة})",
      "})"
    ],
    "description": "إنشاء Promise"
  },
  
  "قائمة": {
    "prefix": "قائمة",
    "body": [
      "قائمة<${1:النوع}> ${2:الاسم} = [${3:العناصر}]"
    ],
    "description": "تعريف قائمة"
  },
  
  "خريطة": {
    "prefix": "خريطة",
    "body": [
      "خريطة<${1:المفتاح}, ${2:القيمة}> ${3:الاسم} = {",
      "\t${4:مفتاح}: ${5:قيمة},",
      "}"
    ],
    "description": "تعريف خريطة/Dictionary"
  },
  
  "مطابقة": {
    "prefix": "مطابقة",
    "body": [
      "مطابقة ${1:القيمة} {",
      "\t${2:النمط1} => ${3:النتيجة1},",
      "\t${4:النمط2} => ${5:النتيجة2},",
      "\t_ => ${6:النتيجة_الافتراضية}",
      "}"
    ],
    "description": "نمط المطابقة"
  },
  
  "رئيسي": {
    "prefix": "رئيسي",
    "body": [
      "دالة رئيسي() {",
      "\t${1:// الكود الرئيسي}",
      "}",
      "",
      "رئيسي()"
    ],
    "description": "الدالة الرئيسية"
  },
  
  "محدد_سياق": {
    "prefix": "محدد",
    "body": [
      "محدد_سياق (${1:المورد}) {",
      "\t${2:// الكود}",
      "}"
    ],
    "description": "Context Manager"
  },
  
  "مُ Decorator": {
    "prefix": "مُزين",
    "body": [
      "مُزين ${1:الاسم}",
      "دالة ${1:الاسم}(الهدف) {",
      "\t${2:// الكود}",
      "\tأرجع الهدف",
      "}"
    ],
    "description": "Decorator مخصص"
  },
  
  "تصنيف_بيانات": {
    "prefix": "تصنيف",
    "body": [
      "تصنيف_بيانات ${1:الاسم} {",
      "\t${2:الحقل1}: ${3:النوع1}",
      "\t${4:الحقل2}: ${5:النوع2}",
      "}"
    ],
    "description": "Data Class"
  },
  
  "قيمة_افتراضية": {
    "prefix": "افتراضي",
    "body": [
      "${1:المعامل} = ${2:القيمة_الافتراضية}"
    ],
    "description": "معامل بقيمة افتراضية"
  },
  
  "عام": {
    "prefix": "عام",
    "body": [
      "<${1:T}>"
    ],
    "description": "معامل نوع عام"
  },
  
  "Vibe Coding": {
    "prefix": "vibe",
    "body": [
      "// ✨ Vibe Coding: ${1:وصف_ما_تريده}",
      "// سيتم اقتراح كود تلقائياً"
    ],
    "description": "طلب Vibe Coding"
  }
}
