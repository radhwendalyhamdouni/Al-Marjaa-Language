# ═══════════════════════════════════════════════════════════════════════════════
# Al-Marjaa VS Code Extension
# ملف استثناء النشر
# ═══════════════════════════════════════════════════════════════════════════════

# ملفات المصدر (لا تُنشر)
src/**
*.ts
tsconfig.json

# ملفات التطوير
.vscode/**
.vscodeignore
.eslintrc.json
**/*.map

# ملفات Git
.git/**
.gitignore

# ملفات الاختبار
test/**
tests/**
**/*.test.ts
**/*.spec.ts

# ملفات التوثيق المصدر
docs/**
*.md
!README.md

# الملفات المؤقتة
*.log
*.tmp
*.bak
*.cache

# ملفات Node
node_modules/**
package-lock.json
yarn.lock

# ملفات البناء (تُستثنى لأن out/ مطلوب)
# out/**  # لا نستثنيه لأنه مطلوب للنشر

# ملفات أخرى
.DS_Store
Thumbs.db
*.vsix
