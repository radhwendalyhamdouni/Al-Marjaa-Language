#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# لغة المرجع - Pre-remove Script
# ═══════════════════════════════════════════════════════════════════════════════

set -e

# عرض رسالة التأكيد
echo ""
echo "⚠️  جاري إزالة لغة المرجع..."
echo ""

# حفظ التكوين
if [ -d "/etc/almarjaa" ]; then
    echo "📁 تم حفظ ملفات التكوين في /etc/almarjaa/"
fi

# تنظيف الكاش
if [ -d "/var/cache/almarjaa" ]; then
    rm -rf /var/cache/almarjaa
fi

exit 0
