# مثال: الدوال
# يوضح كيفية تعريف واستخدام الدوال

# دالة بسيطة
دالة جمع(أ، ب) {
    أرجع أ + ب؛
}

# دالة مع قيمة افتراضية
دالة تحية(الاسم) {
    أرجع "مرحباً " + الاسم + "!"؛
}

# دالة متعددة الأسطر
دالة حساب_المعدل(الدرجات) {
    متغير المجموع = ٠؛
    لكل درجة في الدرجات {
        المجموع = المجموع + درجة؛
    }
    أرجع المجموع / طول(الدرجات)؛
}

# استخدام الدوال
اطبع(جمع(١٠، ٢٠))؛
اطبع(تحية("محمد"))؛

متغير درجاتي = [٨٥، ٩٠، ٧٨، ٩٢]؛
اطبع("المعدل: " + نص(حساب_المعدل(درجاتي)))؛
