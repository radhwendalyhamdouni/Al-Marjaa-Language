# مثال: المتغيرات والثوابت
# يوضح كيفية تعريف واستخدام المتغيرات

# تعريف متغيرات
متغير الاسم = "أحمد"؛
متغير العمر = ٢٥؛
متغير الطول = ١٧٥.٥؛

# تعريف ثابت
ثابت pi = ٣.١٤١٥٩؛

اطبع("الاسم: " + الاسم)؛
اطبع("العمر: " + نص(العمر))؛

# تعديل قيمة المتغير
العمر = العمر + ١؛
اطبع("العمر الجديد: " + نص(العمر))؛

# استخدام الثابت
متغير مساحة = pi * ٥ * ٥؛
اطبع("مساحة الدائرة: " + نص(مساحة))؛
