# مثال: الشروط
# يوضح كيفية استخدام الجمل الشرطية

متغير الدرجة = ٨٥؛

# شرط بسيط
إذا الدرجة >= ٩٠ {
    اطبع("ممتاز!")؛
} وإلا إذا الدرجة >= ٨٠ {
    اطبع("جيد جداً")؛
} وإلا إذا الدرجة >= ٧٠ {
    اطبع("جيد")؛
} وإلا إذا الدرجة >= ٦٠ {
    اطبع("مقبول")؛
} وإلا {
    اطبع("راسب")؛
}

# استخدام المنطق
متغير س = ١٠؛
متغير ص = ٢٠؛

إذا س < ص و ص > ١٥ {
    اطبع("الشرط صحيح")؛
}

إذا ليس (س == ص) {
    اطبع("س لا يساوي ص")؛
}
