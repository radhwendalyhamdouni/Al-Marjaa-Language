# اختبار مشغل الانتشار - Spread Operator

متغير قائمة_١ = [١، ٢، ٣]؛
متغير قائمة_٢ = [٤، ٥، ٦]؛

# دمج قائمتين
متغير مدموج = [...قائمة_١، ...قائمة_٢]؛
اطبع("القائمة المدموجة:"، مدموج)؛

# إضافة عناصر في المنتصف
متغير مختلط = [٠، ...قائمة_١، ١٠٠، ...قائمة_٢]؛
اطبع("القائمة المختلطة:"، مختلط)؛

# إنشاء نسخة
متغير نسخة = [...قائمة_١]؛
اطبع("النسخة:"، نسخة)؛
