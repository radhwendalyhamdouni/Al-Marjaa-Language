\section{Evaluation}

\subsection{Test Results}

\begin{table}[h]
\centering
\caption{Unit Test Results \textarabic{نَتائِجِ الاِختِبارات}}
\label{tab:tests}
\begin{tabular}{@{}lcccc@{}}
\toprule
\textbf{Category} & \textbf{Total} & \textbf{Passed} & \textbf{Failed} & \textbf{Rate} \\
\midrule
Lexer Tests & 33 & 33 & 0 & 100\% \\
Parser Tests & 68 & 68 & 0 & 100\% \\
Interpreter Tests & 215 & 215 & 0 & 100\% \\
CLI Tests & 21 & 19 & 2 & 90.5\% \\
Other Tests & 6 & 6 & 0 & 100\% \\
\midrule
\textbf{Total} & \textbf{343} & \textbf{341} & \textbf{2} & \textbf{99.4\%} \\
\bottomrule
\end{tabular}
\end{table}

\subsection{Performance Benchmarks}

\begin{table}[h]
\centering
\caption{Performance Results \textarabic{نَتائِجِ الأَداء}}
\label{tab:perf}
\begin{tabular}{@{}llll@{}}
\toprule
\textbf{Benchmark} & \textbf{Iterations} & \textbf{Time} & \textbf{Ops/sec} \\
\midrule
Arithmetic & 100,000 & 27ms & 3.6M \\
Loops & 10,000 & 1.4ms & 7.0M \\
Fibonacci & 50,000 & 8.5ms & 5.9M \\
Matrix Mult & 50,000 & 51ms & 981K \\
Stress Test & 1,000 & 50ms & 19.9M \\
\bottomrule
\end{tabular}
\end{table}

\textbf{Overall JIT Speedup: 5.08x}

