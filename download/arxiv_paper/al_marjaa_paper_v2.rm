\section{Code Examples}

\subsection{Hello World}

\begin{lstlisting}[caption=Hello World in Al-Marjaa]
اطبع("مرحباً بالعالم!")؛
\end{lstlisting}

\subsection{Vibe Coding}

\begin{lstlisting}[caption=Vibe Coding Example]
// الإدخال باللغة الطبيعية العربية
"أنشئ دالة تجمع رقمين"

// الكود المُنتَج تلقائياً:
دالة جمع(أ، ب) {
    أرجع أ + ب؛
}
\end{lstlisting}

\subsection{Neural Network}

\begin{lstlisting}[caption=Neural Network in Al-Marjaa]
// إنشاء شبكة عصبية
متغير شبكة = شبكة_عصبية()؛
شبكة.أضف_طبقة(128، "relu")؛
شبكة.أضف_طبقة(64، "relu")؛
شبكة.أضف_طبقة(10، "softmax")؛

// التدريب
شبكة.درّب(بيانات_التدريب، 100، 0.01)؛

// الاستدلال
متغير نتيجة = شبكة.مرّر(المدخل)؛
\end{lstlisting}

