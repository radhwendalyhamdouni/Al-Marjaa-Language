\section{Code Examples in Multiple Languages}

\subsection{Hello World}

\begin{lstlisting}[caption={Hello World in Multiple Languages}]
// Arabic
اطبع("مرحباً بالعالم!")؛

// Chinese
打印("你好，世界！")；

// Spanish
imprimir("Hola, mundo!");

// Russian
вывести("Привет, мир!");

// Hindi
मुद्रित_करें("नमस्ते दुनिया!")।

// Japanese
印刷("こんにちは、世界！");
\end{lstlisting}

\subsection{Factorial Function}

\begin{lstlisting}[caption={Factorial in Multiple Languages}]
// Arabic
دالة مضروب(ن) {
    إذا ن <= 1 { أرجع 1؛ }
    أرجع ن * مضروب(ن - 1)؛
}

// Chinese
函数 阶乘(n) {
    如果 n <= 1 { 返回 1； }
    返回 n * 阶乘(n - 1)；
}

// Spanish
funcion factorial(n) {
    si n <= 1 { retornar 1; }
    retornar n * factorial(n - 1);
}

// Russian
функция факториал(n) {
    если n <= 1 { вернуть 1; }
    вернуть n * факториал(n - 1);
}
\end{lstlisting}

\subsection{Class Definition}

\begin{lstlisting}[caption={OOP in Multiple Languages}]
// Arabic
صنف حيوان {
    متغير الاسم؛
    دالة حيوان(الاسم) { هذا.الاسم = الاسم؛ }
    دالة صوت() { أرجع "صوت عام"؛ }
}

// Chinese
类 动物 {
    变量 名字；
    函数 动物(名字) { 这.名字 = 名字； }
    函数 叫声() { 返回 "普通叫声"； }
}

// Spanish
clase Animal {
    variable nombre;
    funcion Animal(nombre) { este.nombre = nombre; }
    funcion sonido() { retornar "sonido general"; }
}
\end{lstlisting}

\section{Vibe Coding Examples}

\subsection{Arabic}

\begin{lstlisting}[caption={Arabic Vibe Coding}]
"أنشئ دالة تحسب متوسط قائمة من الأرقام"
// Generated:
دالة متوسط(قائمة) {
    متغير مجموع = 0؛
    لكل عنصر في قائمة {
        مجموع = مجموع + عنصر؛
    }
    أرجع مجموع / طول(قائمة)؛
}
\end{lstlisting}

\subsection{Chinese}

\begin{lstlisting}[caption={Chinese Vibe Coding}]
"创建一个函数计算数字列表的平均值"
// Generated:
函数 平均值(列表) {
    变量 总和 = 0；
    对于每个 元素 在 列表 {
        总和 = 总和 + 元素；
    }
    返回 总和 / 长度(列表)；
}
\end{lstlisting}

\subsection{Spanish}

\begin{lstlisting}[caption={Spanish Vibe Coding}]
"crear funcion que calcule el promedio de una lista de numeros"
// Generated:
funcion promedio(lista) {
    variable suma = 0;
    para_cada elemento en lista {
        suma = suma + elemento;
    }
    retornar suma / longitud(lista);
}
\end{lstlisting}

\section{Framework Extension Guide}

\subsection{Adding a New Language}

To add support for a new language:

\begin{enumerate}
    \item Create language directory: \texttt{src/languages/newlanguage/}
    \item Create keyword configuration: \texttt{keywords.yaml}
    \item Create grammar configuration: \texttt{grammar.yaml}
    \item Create error messages: \texttt{errors.yaml}
    \item Add NLP model or use multilingual model
    \item Test with example programs
\end{enumerate}

\begin{lstlisting}[caption={Template for New Language}]
// src/languages/swahili/keywords.yaml
keywords:
  variable: "badilisha"
  function: "kazi"
  class: "darasa"
  if: "ikiwa"
  else: "vinginevyo"
  for_each: "kwa_kila"
  while: "wakati"
  return: "rudisha"
\end{lstlisting}

